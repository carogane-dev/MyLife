// Schéma de base de données - point de départ
// On y ajoutera les modèles au fur et à mesure des fonctionnalités

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id                 String              @id @default(uuid())
  email              String              @unique
  passwordHash       String
  createdAt          DateTime            @default(now())
  meals              MealEntry[]
  sessions           Session[]
  fridgeItems        FridgeItem[]
  nutritionProfile   NutritionProfile?
  consumptionEntries ConsumptionEntry[]
  recipes            Recipe[]
  recipeLikes        RecipeLike[]
}

// Profil physiologique nécessaire au calcul futur des besoins caloriques
// (BMR puis TDEE = BMR × multiplicateur d'activité : sédentaire ×1.2,
// léger ×1.375, modéré ×1.55, actif ×1.725, très actif ×1.9).
model NutritionProfile {
  id     String @id @default(uuid())
  user   User   @relation(fields: [userId], references: [id])
  userId String @unique

  sex           String // "homme" | "femme" — pour la formule BMR uniquement
  age           Int // saisi via curseur, pas une date de naissance
  heightCm      Float
  weightKg      Float
  activityLevel String // "sedentaire" | "leger" | "modere" | "actif" | "tres_actif"
  goalMode      String  @default("ligne") // "precision" | "ligne" | "elite" | "frigo_only"
  bodyType      String? // "endurance" | "athletic" | "mass" — utilisé uniquement si goalMode === "elite"

  // Répartition intra-journalière des calories (petit-déjeuner/déjeuner/dîner),
  // en fraction de la cible journalière. Nullable : null = utiliser les
  // valeurs par défaut de NutritionBenchmark. Pas encore d'écran de réglage
  // pour ces champs (prévu plus tard) — le champ existe pour ne pas avoir à
  // migrer une seconde fois quand cet écran arrivera.
  breakfastCaloriePercent Float?
  lunchCaloriePercent     Float?
  dinnerCaloriePercent    Float?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

// Paramètres de calcul par mode d'objectif (et morphologie pour "elite"),
// déplacés en base pour être ajustables sans déploiement de code — voir
// api/src/nutritionCalculator.ts pour leur utilisation. `source` documente
// la justification scientifique (AMDR/ISSN) ou, à défaut, marque
// explicitement un choix produit assumé plutôt que dérivé d'un repère.
model NutritionModeConfig {
  id                String  @id @default(uuid())
  goalMode          String // "chill" | "ligne" | "elite"
  bodyType          String? // non-null seulement si goalMode === "elite"
  calorieMultiplier Float
  proteinPerKg      Float
  fatPercent        Float
  source            String

  updatedAt DateTime @updatedAt

  @@unique([goalMode, bodyType])
}

// Repères nutritionnels reconnus (AMDR de l'Institute of Medicine, ISSN pour
// les protéines sportives) et répartition intra-journalière par défaut.
// Ligne singleton (une seule rangée), lue via findFirst côté backend.
model NutritionBenchmark {
  id String @id @default(uuid())

  carbPercentMin    Float @default(0.45)
  carbPercentMax    Float @default(0.65)
  fatPercentMin     Float @default(0.20)
  fatPercentMax     Float @default(0.35)
  proteinPercentMin Float @default(0.10)
  proteinPercentMax Float @default(0.35)

  issnProteinPerKgMin Float @default(1.6)
  issnProteinPerKgMax Float @default(2.2)

  // Milieux des fourchettes documentées (20-25 / 35-40 / 25-30 %) : somment
  // à 87.5%, volontairement — voir normalizedSlotShare() dans mealSlots.ts
  // qui les normalise à l'usage plutôt que de forcer 100% ici, pour garder
  // la traçabilité des valeurs telles que citées dans leur source.
  defaultBreakfastPercent Float @default(0.225)
  defaultLunchPercent     Float @default(0.375)
  defaultDinnerPercent    Float @default(0.275)

  updatedAt DateTime @updatedAt
}

model Session {
  id        String   @id // token aléatoire généré en code, pas un uuid
  user      User     @relation(fields: [userId], references: [id])
  userId    String
  expiresAt DateTime
  createdAt DateTime @default(now())
}

model FridgeItem {
  id          String   @id @default(uuid())
  user        User     @relation(fields: [userId], references: [id])
  userId      String
  category    String // ex. "Fromage", "Viande", "Légume", "Fruit"
  subcategory String // ex. "Chèvre", "Vache", "Bœuf"
  name        String // ex. "Crottin de Chavignol"
  quantity    Float
  unit        String // ex. "pièce", "g", "kg", "L"
  barcode     String?

  // Poids en grammes d'une unité, utilisé pour convertir `quantity` en
  // grammes lors du calcul des macros (toujours exprimées "pour 100g").
  // Sans objet quand `unit` est déjà "g"/"kg"/"L" (conversion standard) ;
  // pertinent uniquement pour "pièce" ou une unité libre similaire, où
  // `quantity` est un nombre d'exemplaires et non un poids. Repli à 100g
  // si non renseigné (cohérent avec les valeurs de repli de nutritionDefaults.ts).
  unitWeightGrams Float?

  // Créneaux de repas compatibles : "petit-dejeuner" | "dejeuner" | "diner".
  // Un article peut être compatible avec plusieurs créneaux mais pas
  // forcément tous (ex. un plat du soir absent du petit-déjeuner) — jamais
  // déduit à la volée, toujours choisi explicitement (par défaut les 3
  // valeurs à la création, voir POST /api/fridge).
  compatibleSlots String[] @default([])

  // Toujours fournie explicitement par l'app (validation POST /api/fridge) ;
  // le défaut n'existe que pour permettre la migration sur les lignes
  // déjà existantes. Jamais issue du code-barres (OFF ne connaît pas la
  // date de péremption d'un exemplaire physique, elle varie par lot).
  expiresAt DateTime @default(now())

  // Toujours renseignées : valeur réelle du code-barres si disponible,
  // sinon valeur type de la catégorie (voir nutritionDefaults.ts).
  caloriesPer100g    Float   @default(0)
  proteinPer100g     Float   @default(0)
  fatPer100g         Float   @default(0)
  carbsPer100g       Float   @default(0)
  nutritionEstimated Boolean @default(false)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([userId, category, subcategory])
}

// Journal de consommation : "marquer comme mangé" un article du frigo.
// Distinct de MealEntry (photo + IA), qui reste dédié à la reconnaissance
// de plats à venir — ici, les macros sont connues précisément (issues du
// FridgeItem au moment de la consommation) et servent au tableau de bord
// calorique journalier/hebdomadaire.
model ConsumptionEntry {
  id     String @id @default(uuid())
  user   User   @relation(fields: [userId], references: [id])
  userId String

  // Pas de relation Prisma vers FridgeItem : l'article peut être
  // entièrement consommé (et donc supprimé) sans perdre l'historique.
  fridgeItemId String?
  name         String
  quantity     Float
  unit         String
  calories     Float
  protein      Float
  fat          Float
  carbs        Float

  // Créneau auquel ce repas a été enregistré : "petit-dejeuner" | "dejeuner"
  // | "diner". Nullable pour rester compatible avec l'historique déjà
  // enregistré avant l'introduction des créneaux.
  mealSlot String?

  consumedAt DateTime @default(now())

  @@index([userId, consumedAt])
}

model MealEntry {
  id          String   @id @default(uuid())
  user        User     @relation(fields: [userId], references: [id])
  userId      String
  photoUrl    String?
  dishName    String?  // reconnu par l'IA, éditable par l'utilisateur
  aiRawResult Json?    // réponse brute du modèle de vision, pour audit/amélioration
  eatenAt     DateTime @default(now())
  createdAt   DateTime @default(now())
}

// Base de recettes communautaire : publique, visible et likable par tous
// les comptes, indépendante du frigo de chacun (sert de bibliothèque
// d'inspiration/de base pour le composeur de repas, voir RecipeIngredient
// pour le mécanisme d'ingrédients "libres").
model Recipe {
  id           String   @id @default(uuid())
  author       User     @relation(fields: [authorId], references: [id])
  authorId     String
  name         String
  description  String?
  instructions String // étapes de préparation, texte libre

  category   String // "Petit-déjeuner" | "Plat" | "Entrée" | "Dessert" | "Snack"
  healthy    Boolean @default(false) // repas "orienté healthy" pour le tri/filtre
  difficulty String // "facile" | "moyen" | "difficile"

  prepMinutes Int
  cookMinutes Int
  servings    Int // nombre de portions couvertes par les quantités de référence

  // Créneaux de repas compatibles : "petit-dejeuner" | "dejeuner" | "diner".
  // Distinct de `category` (type culinaire du plat) : une recette catégorie
  // "Plat" peut être compatible déjeuner+dîner sans l'être petit-déjeuner.
  // Champ requis (au moins une valeur) à la création/édition.
  compatibleSlots String[] @default([])

  ingredients RecipeIngredient[]
  likes       RecipeLike[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([category])
  @@index([healthy])
}

model RecipeIngredient {
  id       String @id @default(uuid())
  recipe   Recipe @relation(fields: [recipeId], references: [id], onDelete: Cascade)
  recipeId String

  name String // ex. "Blanc de poulet", "Œufs"

  // Quantité/unité montrées à l'utilisateur (ex. "2" / "pièces") séparées du
  // poids réel utilisé pour les macros (ex. 110g) : évite toute ambiguïté
  // du type "1 pièce = 1 gramme" déjà rencontrée sur le frigo.
  displayQuantity Float
  displayUnit     String
  referenceGrams  Float

  caloriesPer100g Float
  proteinPer100g  Float
  fatPer100g      Float
  carbsPer100g    Float

  // Ingrédient "libre" : sa quantité peut être ajustée indépendamment (en
  // plus ou en moins) par le composeur de repas pour coller à l'objectif
  // nutritionnel, sans dénaturer la recette (ex. poulet, sauce, féculent
  // d'accompagnement). Les ingrédients non-libres forment le "socle" de la
  // recette : ils sont toujours mis à l'échelle ENSEMBLE par un même
  // facteur (les proportions entre eux restent fixes, ex. œufs+lait d'une
  // omelette), jamais individuellement.
  flexible Boolean @default(false)

  order Int @default(0)
}

model RecipeLike {
  id       String @id @default(uuid())
  user     User   @relation(fields: [userId], references: [id])
  userId   String
  recipe   Recipe @relation(fields: [recipeId], references: [id], onDelete: Cascade)
  recipeId String

  createdAt DateTime @default(now())

  @@unique([userId, recipeId])
}
